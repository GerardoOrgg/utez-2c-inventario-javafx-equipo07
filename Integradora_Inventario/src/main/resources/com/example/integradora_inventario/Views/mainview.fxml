<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.text.Font?>

<VBox prefHeight="600.0" prefWidth="900.0" spacing="0.0"
      style="-fx-background-color: #f4f4f9;"
      xmlns="http://javafx.com/javafx/17.0.12"
      xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="com.example.integradora_inventario.Controllers.MainController">

    <AnchorPane prefHeight="80.0" style="-fx-background-color: #2c3e50;">
        <children>
            <Label layoutX="25.0" layoutY="25.0" text="SISTEMA DE INVENTARIO" textFill="WHITE">
                <font>
                    <Font name="System Bold" size="22.0" />
                </font>
            </Label>
            <Label layoutX="25.0" layoutY="52.0" text="Control de Productos y Stock" textFill="#bdc3c7" >
                <font>
                    <Font size="13.0" />
                </font>
            </Label>
        </children>
    </AnchorPane>

    <HBox alignment="CENTER_LEFT" prefHeight="70.0" spacing="15.0" style="-fx-background-color: white; -fx-border-color: #dcdde1; -fx-border-width: 0 0 1 0;">
        <padding>
            <Insets left="20.0" right="20.0" />
        </padding>
        <children>
            <VBox alignment="CENTER_LEFT" HBox.hgrow="ALWAYS">
                <children>
                    <Label text="Buscar Producto" textFill="#7f8c8d">
                        <font>
                            <Font size="11.0" />
                        </font>
                    </Label>
                    <TextField fx:id="txtBuscar" maxWidth="400.0" promptText="🔍 Digite código o nombre..."
                               style="-fx-background-radius: 20; -fx-border-radius: 20; -fx-padding: 5 15;" />
                </children>
            </VBox>

            <Button onAction="#recargar" style="-fx-background-color: #95a5a6; -fx-text-fill: white; -fx-cursor: hand;" text="🔄 Recargar" />
        </children>
    </HBox>

    <StackPane VBox.vgrow="ALWAYS">
        <padding>
            <Insets bottom="10.0" left="20.0" right="20.0" top="20.0" />
        </padding>
        <children>
            <TableView fx:id="tablaProductos" style="-fx-background-radius: 5; -fx-border-radius: 5; -fx-border-color: #dcdde1;">
                <columns>
                    <TableColumn fx:id="Codigo" prefWidth="100" text="COD" />
                    <TableColumn fx:id="Nombre" prefWidth="280" text="PRODUCTO" />
                    <TableColumn fx:id="Precio" prefWidth="120" text="PRECIO UNIT." />
                    <TableColumn fx:id="Stock" prefWidth="100" text="EXISTENCIA" />
                    <TableColumn fx:id="Categoria" prefWidth="150" text="CATEGORÍA" />
                </columns>
                <columnResizePolicy>
                    <TableView fx:constant="CONSTRAINED_RESIZE_POLICY" />
                </columnResizePolicy>
            </TableView>
        </children>
    </StackPane>

    <HBox alignment="CENTER_RIGHT" prefHeight="80.0" spacing="15.0">
        <padding>
            <Insets left="20.0" right="20.0" />
        </padding>
        <children>
            <Button onAction="#eliminar" prefHeight="40.0" prefWidth="120.0"
                    style="-fx-background-color: #e74c3c; -fx-text-fill: white; -fx-font-weight: bold; -fx-background-radius: 5; -fx-cursor: hand;" text="ELIMINAR" />

            <Separator orientation="VERTICAL" prefHeight="40.0" />

            <Button onAction="#editar" prefHeight="40.0" prefWidth="120.0"
                    style="-fx-background-color: #f1c40f; -fx-text-fill: #2c3e50; -fx-font-weight: bold; -fx-background-radius: 5; -fx-cursor: hand;" text="EDITAR" />

            <Button onAction="#nuevo" prefHeight="40.0" prefWidth="140.0"
                    style="-fx-background-color: #2ecc71; -fx-text-fill: white; -fx-font-weight: bold; -fx-background-radius: 5; -fx-cursor: hand;" text="+ NUEVO PRODUCTO" />
        </children>
    </HBox>

</VBox>