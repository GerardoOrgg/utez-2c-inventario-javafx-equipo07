<?xml version="1.0" encoding="UTF-8"?>

        <?import javafx.scene.control.*?>
        <?import javafx.scene.layout.*?>

<VBox spacing="10" xmlns="http://javafx.com/javafx"
      xmlns:fx="http://javafx.com/fxml"
      fx:controller="com.example.integradora_inventario.Controllers.FormController"
      prefWidth="400"
      style="-fx-padding: 15;">

<Label text="Editar producto" style="-fx-font-size: 16px; -fx-font-weight: bold;" />

<GridPane hgap="10" vgap="10">

    <Label text="Código:" GridPane.rowIndex="0" GridPane.columnIndex="0"/>
    <TextField fx:id="txtCodigo" GridPane.rowIndex="0" GridPane.columnIndex="1"/>

    <Label text="Nombre:" GridPane.rowIndex="1" GridPane.columnIndex="0"/>
    <TextField fx:id="txtNombre" GridPane.rowIndex="1" GridPane.columnIndex="1"/>

    <Label text="Precio:" GridPane.rowIndex="2" GridPane.columnIndex="0"/>
    <TextField fx:id="txtPrecio" GridPane.rowIndex="2" GridPane.columnIndex="1"/>

    <Label text="Stock:" GridPane.rowIndex="3" GridPane.columnIndex="0"/>
    <TextField fx:id="txtStock" GridPane.rowIndex="3" GridPane.columnIndex="1"/>

    <Label text="Categoría:" GridPane.rowIndex="4" GridPane.columnIndex="0"/>
    <ComboBox fx:id="txtcategoria" GridPane.rowIndex="4" GridPane.columnIndex="1"/>

</GridPane>



<HBox spacing="10" alignment="CENTER_RIGHT">
    <Button text="Confirmar" onAction="#editarBtn"/>
    <Button text="Salir" onAction="#salir"/>
</HBox>

</VBox>