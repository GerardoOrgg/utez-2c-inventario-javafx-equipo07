<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<VBox spacing="10"
      prefHeight="500.0" prefWidth="850.0"
      xmlns="http://javafx.com/javafx/17.0.12"
      xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="com.example.integradora_inventario.Controllers.MainController"
      style="-fx-padding: 10;">

    <Label text="Gestión de Inventario de Productos"
           style="-fx-font-size: 18px; -fx-font-weight: bold;" />

    <HBox spacing="10">
        <Label text="Buscar:" />
        <TextField fx:id="txtBuscar" promptText="Buscar por código o nombre..." HBox.hgrow="ALWAYS"/>
    </HBox>

    <TableView fx:id="tablaProductos" VBox.vgrow="ALWAYS">
        <columns>
            <TableColumn fx:id="Codigo" text="Código" prefWidth="100" />
            <TableColumn fx:id="Nombre" text="Nombre" prefWidth="250" />
            <TableColumn fx:id="Precio" text="Precio" prefWidth="100" />
            <TableColumn fx:id="Stock" text="Stock" prefWidth="100" />
            <TableColumn fx:id="Categoria" text="Categoría" prefWidth="150" />
        </columns>
    </TableView>

    <HBox spacing="10" alignment="CENTER_RIGHT">
        <Button text="Nuevo" onAction="#nuevo"/>
        <Button text="Editar" onAction="#editar" />
        <Button text="Eliminar" onAction="#eliminar"/>
        <Button text="Recargar" onAction="#recargar"/>
    </HBox>

</VBox>