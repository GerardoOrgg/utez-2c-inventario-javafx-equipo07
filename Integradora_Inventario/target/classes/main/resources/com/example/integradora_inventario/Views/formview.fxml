<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.text.Font?>

<VBox prefWidth="450.0" spacing="0.0" style="-fx-background-color: #f4f4f9; -fx-background-radius: 10; -fx-border-radius: 10;"
      xmlns="http://javafx.com/javafx/17.0.12"
      xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="com.example.integradora_inventario.Controllers.FormController">

    <AnchorPane prefHeight="60.0" style="-fx-background-color: #2c3e50; -fx-background-radius: 10 10 0 0;">
        <children>
            <Label layoutX="20.0" layoutY="18.0" text="NUEVO PRODUCTO" textFill="WHITE">
                <font>
                    <Font name="System Bold" size="18.0" />
                </font>
            </Label>
        </children>
    </AnchorPane>

    <VBox spacing="15.0" style="-fx-padding: 25;">
        <children>
            <GridPane hgap="15.0" vgap="15.0">
                <columnConstraints>
                    <ColumnConstraints hgrow="SOMETIMES" maxWidth="150.0" minWidth="80.0" prefWidth="100.0" />
                    <ColumnConstraints hgrow="ALWAYS" minWidth="200.0" />
                </columnConstraints>

                <rowConstraints>
                    <RowConstraints minHeight="35.0" vgrow="SOMETIMES" />
                    <RowConstraints minHeight="35.0" vgrow="SOMETIMES" />
                    <RowConstraints minHeight="35.0" vgrow="SOMETIMES" />
                    <RowConstraints minHeight="35.0" vgrow="SOMETIMES" />
                    <RowConstraints minHeight="35.0" vgrow="SOMETIMES" />
                </rowConstraints>

                <children>
                    <Label text="Código:" textFill="#34495e" GridPane.rowIndex="0">
                        <font>
                            <Font name="System Bold" size="13.0" />
                        </font>
                    </Label>
                    <TextField fx:id="txtCodigo" prefHeight="35.0" promptText="Ej: 101"
                               style="-fx-background-radius: 5; -fx-border-color: #dcdde1; -fx-border-radius: 5;" GridPane.columnIndex="1" GridPane.rowIndex="0" />

                    <Label text="Nombre:" textFill="#34495e" GridPane.rowIndex="1">
                        <font>
                            <Font name="System Bold" size="13.0" />
                        </font>
                    </Label>
                    <TextField fx:id="txtNombre" prefHeight="35.0" promptText="Nombre del artículo"
                               style="-fx-background-radius: 5; -fx-border-color: #dcdde1; -fx-border-radius: 5;" GridPane.columnIndex="1" GridPane.rowIndex="1" />

                    <Label text="Precio:" textFill="#34495e" GridPane.rowIndex="2">
                        <font>
                            <Font name="System Bold" size="13.0" />
                        </font>
                    </Label>
                    <TextField fx:id="txtPrecio" prefHeight="35.0" promptText="0.00"
                               style="-fx-background-radius: 5; -fx-border-color: #dcdde1; -fx-border-radius: 5;" GridPane.columnIndex="1" GridPane.rowIndex="2" />

                    <Label text="Stock:" textFill="#34495e" GridPane.rowIndex="3">
                        <font>
                            <Font name="System Bold" size="13.0" />
                        </font>
                    </Label>
                    <TextField fx:id="txtStock" prefHeight="35.0" promptText="0"
                               style="-fx-background-radius: 5; -fx-border-color: #dcdde1; -fx-border-radius: 5;" GridPane.columnIndex="1" GridPane.rowIndex="3" />

                    <Label text="Categoría:" textFill="#34495e" GridPane.rowIndex="4">
                        <font>
                            <Font name="System Bold" size="13.0" />
                        </font>
                    </Label>
                    <ComboBox fx:id="txtcategoria" maxWidth="1.7976931348623157E308" prefHeight="35.0"
                              promptText="Seleccione categoría..." style="-fx-background-radius: 5;"
                              GridPane.columnIndex="1" GridPane.rowIndex="4" />
                </children>
            </GridPane>

            <Separator prefWidth="200.0">
                <VBox.margin>
                    <Insets top="10.0" />
                </VBox.margin>
            </Separator>

            <HBox alignment="CENTER_RIGHT" spacing="15.0">
                <children>
                    <Button onAction="#salir" prefHeight="35.0" prefWidth="90.0"
                            style="-fx-background-color: #bdc3c7; -fx-text-fill: #2c3e50; -fx-font-weight: bold; -fx-cursor: hand;" text="SALIR" />
                    <Button onAction="#guardar" prefHeight="35.0" prefWidth="120.0"
                            style="-fx-background-color: #3498db; -fx-text-fill: white; -fx-font-weight: bold; -fx-cursor: hand;" text="GUARDAR" />
                </children>
            </HBox>
        </children>
    </VBox>
</VBox>